<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MacinRender.Gui.ViewModels"
             xmlns:svc="using:MacinRender.Gui.Services"
             xmlns:ctrl="using:MacinRender.Gui.Controls"
             x:Class="MacinRender.Gui.Views.SemanticEditorView"
             x:DataType="vm:SemanticEditorViewModel">

    <UserControl.Resources>
        <!-- 电平表渐变(固定刻度色):低位绿 → 中段黄 → 接近 0 dBFS 红。表条按填充宽度裁剪揭示。 -->
        <LinearGradientBrush x:Key="MeterBrush" StartPoint="0%,0%" EndPoint="100%,0%">
            <GradientStop Offset="0.0" Color="#34C759"/>
            <GradientStop Offset="0.62" Color="#5BD66B"/>
            <GradientStop Offset="0.80" Color="#E3CC3F"/>
            <GradientStop Offset="0.92" Color="#FF9F0A"/>
            <GradientStop Offset="1.0" Color="#FF453A"/>
        </LinearGradientBrush>
    </UserControl.Resources>

    <UserControl.Styles>
        <!-- 紧凑数值输入框:压掉 Fluent TextBox 默认的高 MinHeight / 厚内边距,缩到文字大小。 -->
        <Style Selector="TextBox.numeric">
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Padding" Value="4,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <!-- 电平表填充:Width 过渡,使两次轮询(~33ms)间的宽度变化滑动而非跳变。 -->
        <Style Selector="Border.meterfill">
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Width" Duration="0:0:0.06" Easing="LinearEasing"/>
                </Transitions>
            </Setter>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*" Margin="8,0,16,16">
        <StackPanel Grid.Row="0" Margin="2,6,0,12" Spacing="2">
            <TextBlock Classes="h1" FontSize="20" Text="{DynamicResource NavSemantic}"/>
            <TextBlock Classes="muted" Text="{DynamicResource SemanticPageDesc}"/>
        </StackPanel>

        <Grid Grid.Row="1" RowDefinitions="Auto,Auto,*">

            <!-- 载入栏(右侧:导出生效 ADM + 载入文件;导出填掉原来的空白) -->
            <ctrl:SquircleBorder Grid.Row="0" Classes="card" Margin="0,0,0,12">
                <DockPanel>
                    <ctrl:SquircleButton DockPanel.Dock="Right" Classes="headericon accent"
                            VerticalAlignment="Center" Margin="8,0,0,0"
                            IsEnabled="{Binding !IsLoading}" Click="OnLoadFile"
                            ToolTip.Tip="{DynamicResource SemLoadFile}">
                        <Grid Width="24" Height="24" IsHitTestVisible="False">
                            <Path Classes="icon" Data="{StaticResource IconFolder}"/>
                        </Grid>
                    </ctrl:SquircleButton>
                    <ctrl:SquircleButton DockPanel.Dock="Right" Classes="headericon" VerticalAlignment="Center"
                            IsEnabled="{Binding CanExport}" Click="OnExport"
                            ToolTip.Tip="{DynamicResource SemExport}">
                        <Grid Width="24" Height="24" IsHitTestVisible="False">
                            <Path Classes="icon" Data="{StaticResource IconDownload}"/>
                        </Grid>
                    </ctrl:SquircleButton>
                    <StackPanel VerticalAlignment="Center" Spacing="2">
                        <TextBlock Classes="h2" Text="{DynamicResource SemFileHeader}"/>
                        <TextBlock Classes="muted" Text="{Binding StatusText}"/>
                        <TextBlock FontSize="12" Foreground="{DynamicResource TextSecondary}" TextTrimming="CharacterEllipsis"
                                   IsVisible="{Binding HasFile}" Text="{Binding LoadedFileName}"/>
                    </StackPanel>
                </DockPanel>
            </ctrl:SquircleBorder>

            <!-- 监听条:传输 + 后端 A/B + 电平表 + 状态(载入栏下,只在已载入文件时可用) -->
            <ctrl:SquircleBorder Grid.Row="1" Classes="card" Margin="0,0,0,12" Padding="12,8"
                                 IsEnabled="{Binding HasFile}">
                <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto,Auto,Auto" ColumnSpacing="10">

                    <!-- 播放器传输键:⏮ 回到开头 · ▶/⏸ 播放/暂停(未监听时自动开监听并播放)。
                         Padding=0 抵掉 accent 给文字用的 16,7 内边距,让图标在按钮内居中。 -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <ctrl:SquircleButton Width="38" Height="32" Padding="0" VerticalAlignment="Center"
                                HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                IsEnabled="{Binding CanSeek}" Command="{Binding SeekToStartCommand}"
                                ToolTip.Tip="{DynamicResource SemMonToStart}">
                            <Canvas Width="24" Height="24" HorizontalAlignment="Center" VerticalAlignment="Center"
                                    IsHitTestVisible="False">
                                <Path Classes="transporticon" Data="{StaticResource IconToStart}"/>
                            </Canvas>
                        </ctrl:SquircleButton>
                        <ctrl:SquircleButton Classes="accent" Width="48" Height="32" Padding="0" VerticalAlignment="Center"
                                HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                IsEnabled="{Binding CanPlay}" Command="{Binding TogglePlayCommand}">
                            <Canvas Width="24" Height="24" HorizontalAlignment="Center" VerticalAlignment="Center"
                                    IsHitTestVisible="False">
                                <Path Classes="transporticon" Data="{StaticResource IconPlay}" IsVisible="{Binding !IsPlaying}"/>
                                <Path Classes="transporticon" Data="{StaticResource IconPause}" IsVisible="{Binding IsPlaying}"/>
                            </Canvas>
                        </ctrl:SquircleButton>
                    </StackPanel>

                    <!-- 当前时间 -->
                    <TextBlock Grid.Column="1" VerticalAlignment="Center" MinWidth="40" FontSize="12"
                               Foreground="{DynamicResource TextPrimary}" Text="{Binding PlayheadText}"/>

                    <!-- seek -->
                    <Slider Grid.Column="2" VerticalAlignment="Center" Minimum="0"
                            Maximum="{Binding DurationSeconds}" Value="{Binding PlayheadSeconds}"
                            IsEnabled="{Binding IsMonitoring}"/>

                    <!-- 总时长 -->
                    <TextBlock Grid.Column="3" VerticalAlignment="Center" MinWidth="40" FontSize="12"
                               Classes="muted" Text="{Binding DurationText}"/>

                    <!-- 后端 A/B + 自定义 HRIR(SOFA,仅「双耳·SAF」时显示) -->
                    <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <ComboBox Width="154" VerticalAlignment="Center"
                                  ItemsSource="{Binding MonitorBackends}"
                                  SelectedItem="{Binding SelectedMonitorBackend}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="svc:MonitorBackendOption">
                                    <TextBlock Text="{Binding Label}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <ctrl:SquircleButton Classes="sofabtn" Classes.on="{Binding HasMonitorSofa}" Width="104"
                                IsVisible="{Binding MonitorSofaApplicable}" Click="OnToggleMonitorSofa"
                                ToolTip.Tip="{Binding MonitorSofaSummary}">
                            <Panel>
                                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12"
                                           IsVisible="{Binding !HasMonitorSofa}" Text="HRIR"/>
                                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12"
                                           MaxWidth="82" TextTrimming="CharacterEllipsis"
                                           IsVisible="{Binding HasMonitorSofa}" Text="{Binding MonitorSofaFileName}"/>
                            </Panel>
                        </ctrl:SquircleButton>
                    </StackPanel>

                    <!-- 电平表:L/R 峰值(dBFS,色随电平 低绿近 0 红)+ LUFS 读数(点击在 M/S/I 间切换)。
                         ProgressBar 默认 MinWidth=200,显式 MinWidth=0 压回,否则溢出盖住相邻列。 -->
                    <StackPanel Grid.Column="5" Margin="8,0,0,0" VerticalAlignment="Center" Spacing="2">
                        <Grid ColumnDefinitions="12,150,44" ColumnSpacing="6">
                            <TextBlock Grid.Column="0" Classes="muted" FontSize="10" VerticalAlignment="Center" Text="L"/>
                            <Panel Grid.Column="1" Height="6">
                                <Border CornerRadius="3" Background="{DynamicResource RowBg}"/>
                                <Border Classes="meterfill" HorizontalAlignment="Left" CornerRadius="3" ClipToBounds="True"
                                        Width="{Binding PeakLeftFillWidth}">
                                    <Border Width="150" HorizontalAlignment="Left" Background="{StaticResource MeterBrush}"/>
                                </Border>
                            </Panel>
                            <TextBlock Grid.Column="2" FontSize="10" VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextPrimary}" Text="{Binding PeakLeftText}"/>
                        </Grid>
                        <Grid ColumnDefinitions="12,150,44" ColumnSpacing="6">
                            <TextBlock Grid.Column="0" Classes="muted" FontSize="10" VerticalAlignment="Center" Text="R"/>
                            <Panel Grid.Column="1" Height="6">
                                <Border CornerRadius="3" Background="{DynamicResource RowBg}"/>
                                <Border Classes="meterfill" HorizontalAlignment="Left" CornerRadius="3" ClipToBounds="True"
                                        Width="{Binding PeakRightFillWidth}">
                                    <Border Width="150" HorizontalAlignment="Left" Background="{StaticResource MeterBrush}"/>
                                </Border>
                            </Panel>
                            <TextBlock Grid.Column="2" FontSize="10" VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextPrimary}" Text="{Binding PeakRightText}"/>
                        </Grid>
                        <!-- 点击切换 LUFS 窗(M 瞬时 / S 短期 / I 累计) -->
                        <Button Padding="0" Background="Transparent" BorderThickness="0" Cursor="Hand"
                                Command="{Binding CycleLufsModeCommand}"
                                ToolTip.Tip="LUFS: M=momentary S=short-term I=integrated">
                            <TextBlock FontSize="10" Foreground="{DynamicResource Accent}">
                                <Run Text="{Binding LufsModeLabel}"/><Run Text=" "/><Run Text="{Binding LufsValueText}"/>
                            </TextBlock>
                        </Button>
                    </StackPanel>

                    <!-- 状态(错误 / 到尾):仅有内容时占位,空时不占死宽度 -->
                    <TextBlock Grid.Column="6" VerticalAlignment="Center" FontSize="11"
                               Classes="muted" TextWrapping="Wrap" MaxWidth="96" Text="{Binding MonitorStatus}"/>
                </Grid>
            </ctrl:SquircleBorder>

            <!-- 两栏:对象树 | 编辑器 -->
            <Grid Grid.Row="2" ColumnDefinitions="300,*" ColumnSpacing="12">

                <!-- 对象列表 -->
                <ctrl:SquircleBorder Grid.Column="0" Classes="card">
                    <Grid RowDefinitions="Auto,Auto,*" RowSpacing="8">
                        <TextBlock Grid.Row="0" Classes="h2" Cursor="Hand" DoubleTapped="OnResetAll"
                                   ToolTip.Tip="{DynamicResource SemResetHint}" Text="{DynamicResource SemObjects}"/>
                        <!-- 剥离的主前缀提示(全名仍在每行 tooltip) -->
                        <Border Grid.Row="1" IsVisible="{Binding HasCommonPrefix}"
                                Background="{DynamicResource RowBg}" CornerRadius="8" Padding="8,5">
                            <TextBlock Classes="muted" FontSize="11" TextTrimming="CharacterEllipsis"
                                       ToolTip.Tip="{Binding CommonPrefix}"
                                       Text="{Binding CommonPrefixLabel}"/>
                        </Border>
                        <ListBox Grid.Row="2" ItemsSource="{Binding Rows}"
                                 SelectionMode="Single"
                                 SelectedItem="{Binding SelectedRow}">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:SemanticRow">
                                    <StackPanel Spacing="2" Margin="0,2" ToolTip.Tip="{Binding Tooltip}">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <TextBlock Grid.Column="0" FontSize="13" FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"
                                                       Foreground="{DynamicResource TextPrimary}"
                                                       Text="{Binding DisplayName}"/>
                                            <Border Grid.Column="1" Margin="6,0,0,0" VerticalAlignment="Center"
                                                    Background="{DynamicResource RowBg}" CornerRadius="5" Padding="5,1"
                                                    IsVisible="{Binding ChannelTag, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                                <TextBlock Classes="muted" FontSize="10" Text="{Binding ChannelTag}"/>
                                            </Border>
                                        </Grid>
                                        <TextBlock Classes="muted" FontSize="11"
                                                   TextTrimming="CharacterEllipsis"
                                                   IsVisible="{Binding Meta, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                   Text="{Binding Meta}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </ctrl:SquircleBorder>

                <!-- 编辑器:三栏(当前值 → 覆盖 → 生效值)+ 覆盖行;相对变换(× scale / dB) -->
                <ctrl:SquircleBorder Grid.Column="1" Classes="card">
                    <Grid RowDefinitions="Auto,*" RowSpacing="10">
                        <StackPanel Grid.Row="0" Spacing="1">
                            <TextBlock Classes="h2" Cursor="Hand" DoubleTapped="OnResetRow"
                                       ToolTip.Tip="{DynamicResource SemResetHint}"
                                       Text="{Binding SelectedRow.DisplayName, FallbackValue={x:Null}}"/>
                            <TextBlock Classes="muted" FontSize="11"
                                       Text="{Binding SelectedRow.Meta, FallbackValue={x:Null}}"/>
                        </StackPanel>

                        <!-- 未选中:提示 -->
                        <TextBlock Grid.Row="1" Classes="muted" Opacity="0.7" VerticalAlignment="Top"
                                   IsVisible="{Binding SelectedRow,
                                       Converter={x:Static ObjectConverters.IsNull}}"
                                   Text="{DynamicResource SemSelectHint}"/>

                        <StackPanel Grid.Row="1" Spacing="6"
                                    IsVisible="{Binding SelectedRow,
                                        Converter={x:Static ObjectConverters.IsNotNull}}">
                            <!-- 列头 -->
                            <Grid ColumnDefinitions="80,*,202,*" Margin="0,2,0,2">
                                <TextBlock Grid.Column="1" Classes="muted" FontSize="11"
                                           Text="{DynamicResource SemColCurrent}"/>
                                <TextBlock Grid.Column="2" Classes="muted" FontSize="11"
                                           Text="{DynamicResource SemColOverride}"/>
                                <TextBlock Grid.Column="3" Classes="muted" FontSize="11"
                                           Text="{DynamicResource SemColEffective}"/>
                            </Grid>

                            <!-- gain(dB 偏移) -->
                            <Grid ColumnDefinitions="80,*,202,*">
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" FontWeight="SemiBold"
                                           Cursor="Hand" DoubleTapped="OnResetDim" Tag="{Binding SelectedRow.GainDb}"
                                           ToolTip.Tip="{DynamicResource SemResetHint}"
                                           Foreground="{DynamicResource TextPrimary}" Text="gain"/>
                                <TextBlock Grid.Column="1" VerticalAlignment="Center" Classes="muted"
                                           Text="{Binding SelectedRow.GainDb.CurrentText}"/>
                                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6"
                                            VerticalAlignment="Center">
                                    <CheckBox IsChecked="{Binding SelectedRow.GainDb.Enabled}"/>
                                    <Slider Width="86" VerticalAlignment="Center"
                                            Minimum="{Binding SelectedRow.GainDb.SliderMin}"
                                            Maximum="{Binding SelectedRow.GainDb.SliderMax}"
                                            Value="{Binding SelectedRow.GainDb.Value}"
                                            IsEnabled="{Binding SelectedRow.GainDb.Enabled}"/>
                                    <Grid ColumnDefinitions="12,44,Auto" VerticalAlignment="Center">
                                        <TextBlock Grid.Column="0" HorizontalAlignment="Right" VerticalAlignment="Center"
                                                   FontSize="12" Classes="muted" Text="{Binding SelectedRow.GainDb.UnitPrefix}"/>
                                        <TextBox Grid.Column="1" Classes="numeric" VerticalAlignment="Center"
                                                 Text="{Binding SelectedRow.GainDb.ValueEntry}" KeyDown="OnValueEntryKeyDown"/>
                                        <TextBlock Grid.Column="2" Margin="3,0,0,0" VerticalAlignment="Center"
                                                   FontSize="12" Classes="muted" Text="{Binding SelectedRow.GainDb.UnitSuffix}"/>
                                    </Grid>
                                </StackPanel>
                                <TextBlock Grid.Column="3" VerticalAlignment="Center"
                                           Foreground="{DynamicResource Accent}"
                                           Text="{Binding SelectedRow.GainDb.EffectiveText}"/>
                            </Grid>

                            <!-- diffuse(× scale) -->
                            <Grid ColumnDefinitions="80,*,202,*">
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" FontWeight="SemiBold"
                                           Cursor="Hand" DoubleTapped="OnResetDim" Tag="{Binding SelectedRow.DiffuseScale}"
                                           ToolTip.Tip="{DynamicResource SemResetHint}"
                                           Foreground="{DynamicResource TextPrimary}" Text="diffuse"/>
                                <TextBlock Grid.Column="1" VerticalAlignment="Center" Classes="muted"
                                           Text="{Binding SelectedRow.DiffuseScale.CurrentText}"/>
                                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6"
                                            VerticalAlignment="Center">
                                    <CheckBox IsChecked="{Binding SelectedRow.DiffuseScale.Enabled}"/>
                                    <Slider Width="86" VerticalAlignment="Center"
                                            Minimum="{Binding SelectedRow.DiffuseScale.SliderMin}"
                                            Maximum="{Binding SelectedRow.DiffuseScale.SliderMax}"
                                            Value="{Binding SelectedRow.DiffuseScale.Value}"
                                            IsEnabled="{Binding SelectedRow.DiffuseScale.Enabled}"/>
                                    <Grid ColumnDefinitions="12,44,Auto" VerticalAlignment="Center">
                                        <TextBlock Grid.Column="0" HorizontalAlignment="Right" VerticalAlignment="Center"
                                                   FontSize="12" Classes="muted" Text="{Binding SelectedRow.DiffuseScale.UnitPrefix}"/>
                                        <TextBox Grid.Column="1" Classes="numeric" VerticalAlignment="Center"
                                                 Text="{Binding SelectedRow.DiffuseScale.ValueEntry}" KeyDown="OnValueEntryKeyDown"/>
                                        <TextBlock Grid.Column="2" Margin="3,0,0,0" VerticalAlignment="Center"
                                                   FontSize="12" Classes="muted" Text="{Binding SelectedRow.DiffuseScale.UnitSuffix}"/>
                                    </Grid>
                                </StackPanel>
                                <TextBlock Grid.Column="3" VerticalAlignment="Center"
                                           Foreground="{DynamicResource Accent}"
                                           Text="{Binding SelectedRow.DiffuseScale.EffectiveText}"/>
                            </Grid>

                            <!-- extent(× scale,作用于 W/H/D) -->
                            <Grid ColumnDefinitions="80,*,202,*">
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" FontWeight="SemiBold"
                                           Cursor="Hand" DoubleTapped="OnResetDim" Tag="{Binding SelectedRow.ExtentScale}"
                                           ToolTip.Tip="{DynamicResource SemResetHint}"
                                           Foreground="{DynamicResource TextPrimary}" Text="extent"/>
                                <TextBlock Grid.Column="1" VerticalAlignment="Center" Classes="muted"
                                           TextWrapping="Wrap"
                                           Text="{Binding SelectedRow.ExtentScale.CurrentText}"/>
                                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6"
                                            VerticalAlignment="Center">
                                    <CheckBox IsChecked="{Binding SelectedRow.ExtentScale.Enabled}"/>
                                    <Slider Width="86" VerticalAlignment="Center"
                                            Minimum="{Binding SelectedRow.ExtentScale.SliderMin}"
                                            Maximum="{Binding SelectedRow.ExtentScale.SliderMax}"
                                            Value="{Binding SelectedRow.ExtentScale.Value}"
                                            IsEnabled="{Binding SelectedRow.ExtentScale.Enabled}"/>
                                    <Grid ColumnDefinitions="12,44,Auto" VerticalAlignment="Center">
                                        <TextBlock Grid.Column="0" HorizontalAlignment="Right" VerticalAlignment="Center"
                                                   FontSize="12" Classes="muted" Text="{Binding SelectedRow.ExtentScale.UnitPrefix}"/>
                                        <TextBox Grid.Column="1" Classes="numeric" VerticalAlignment="Center"
                                                 Text="{Binding SelectedRow.ExtentScale.ValueEntry}" KeyDown="OnValueEntryKeyDown"/>
                                        <TextBlock Grid.Column="2" Margin="3,0,0,0" VerticalAlignment="Center"
                                                   FontSize="12" Classes="muted" Text="{Binding SelectedRow.ExtentScale.UnitSuffix}"/>
                                    </Grid>
                                </StackPanel>
                                <TextBlock Grid.Column="3" VerticalAlignment="Center" TextWrapping="Wrap"
                                           Foreground="{DynamicResource Accent}"
                                           Text="{Binding SelectedRow.ExtentScale.EffectiveText}"/>
                            </Grid>

                            <!-- divergence(× scale) -->
                            <Grid ColumnDefinitions="80,*,202,*">
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" FontWeight="SemiBold"
                                           Cursor="Hand" DoubleTapped="OnResetDim" Tag="{Binding SelectedRow.DivergenceScale}"
                                           ToolTip.Tip="{DynamicResource SemResetHint}"
                                           Foreground="{DynamicResource TextPrimary}" Text="divergence"/>
                                <TextBlock Grid.Column="1" VerticalAlignment="Center" Classes="muted"
                                           Text="{Binding SelectedRow.DivergenceScale.CurrentText}"/>
                                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6"
                                            VerticalAlignment="Center">
                                    <CheckBox IsChecked="{Binding SelectedRow.DivergenceScale.Enabled}"/>
                                    <Slider Width="86" VerticalAlignment="Center"
                                            Minimum="{Binding SelectedRow.DivergenceScale.SliderMin}"
                                            Maximum="{Binding SelectedRow.DivergenceScale.SliderMax}"
                                            Value="{Binding SelectedRow.DivergenceScale.Value}"
                                            IsEnabled="{Binding SelectedRow.DivergenceScale.Enabled}"/>
                                    <Grid ColumnDefinitions="12,44,Auto" VerticalAlignment="Center">
                                        <TextBlock Grid.Column="0" HorizontalAlignment="Right" VerticalAlignment="Center"
                                                   FontSize="12" Classes="muted" Text="{Binding SelectedRow.DivergenceScale.UnitPrefix}"/>
                                        <TextBox Grid.Column="1" Classes="numeric" VerticalAlignment="Center"
                                                 Text="{Binding SelectedRow.DivergenceScale.ValueEntry}" KeyDown="OnValueEntryKeyDown"/>
                                        <TextBlock Grid.Column="2" Margin="3,0,0,0" VerticalAlignment="Center"
                                                   FontSize="12" Classes="muted" Text="{Binding SelectedRow.DivergenceScale.UnitSuffix}"/>
                                    </Grid>
                                </StackPanel>
                                <TextBlock Grid.Column="3" VerticalAlignment="Center"
                                           Foreground="{DynamicResource Accent}"
                                           Text="{Binding SelectedRow.DivergenceScale.EffectiveText}"/>
                            </Grid>

                            <TextBlock Classes="muted" FontSize="11" Opacity="0.7" Margin="0,8,0,0"
                                       TextWrapping="Wrap" Text="{Binding OverrideSummary}"/>
                        </StackPanel>
                    </Grid>
                </ctrl:SquircleBorder>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
